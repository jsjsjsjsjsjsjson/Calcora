209 1  ,
# teste si les cercles c1 et c2 sont tangents
def tangentc(c1,c2):
    o1=center(c1)
    o2=center(c2)
    R1=radius2(c1)
    R2=radius2(c2)
    d=distance2(o1,o2)
    return normal(d^2+(R1-R2)^2-2*d*(R1+R2))
,
